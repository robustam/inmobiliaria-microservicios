                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/usuarios" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"García\",\n  \"email\": \"juan@example.com\",\n  \"telefono\": \"+57 300 1234567\",\n  \"direccion\": \"Calle 10 #5-20\",\n  \"ciudad\": \"Bogotá\"\n}"
            }
          }
        },
        {
          "name": "Actualizar Usuario",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/usuarios/{{usuarioId}}" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"García Actualizado\",\n  \"telefono\": \"+57 310 9876543\",\n  \"ciudad\": \"Medellín\"\n}"
            }
          }
        },
        {
          "name": "Eliminar Usuario",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/v1/usuarios/{{usuarioId}}" } }
        }
      ]
    },

