        {
          "name": "Obtener por Email",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/usuarios/email/juan@example.com" } }
        },
        {
          "name": "Obtener por Ciudad",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/usuarios/ciudad/Bogotá" } }
