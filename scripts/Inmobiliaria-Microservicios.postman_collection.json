{
  "info": {
    "name": "Inmobiliaria Microservicios",
    "description": "Colección completa de endpoints para el sistema de microservicios inmobiliaria.\nBase URL: http://localhost:8080 (API Gateway)\n\nFlujo recomendado:\n1. Auth → Register / Login  (guarda el token automáticamente)\n2. Propiedad → Crear propiedad\n3. Reserva → Crear reserva\n4. Reseña → Crear reseña\n5. Reporte → Ver resumen general",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "",                      "type": "string" },
    { "key": "usuarioId",    "value": "1", "type": "string" },
    { "key": "propiedadId",  "value": "1", "type": "string" },
    { "key": "reservaId",    "value": "1", "type": "string" },
    { "key": "resenaId",     "value": "1", "type": "string" },
    { "key": "imagenId",     "value": "1", "type": "string" },
    { "key": "notificacionId","value": "1","type": "string" },
    { "key": "reporteId",    "value": "1", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth Service",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/health" }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"juan\",\n  \"email\": \"juan@example.com\",\n  \"password\": \"Password123!\",\n  \"nombre\": \"Juan García\",\n  \"role\": \"USER\"\n}"
            }
          }
        },
        {
          "name": "Register (Propietario)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"propietario1\",\n  \"email\": \"prop@example.com\",\n  \"password\": \"Password123!\",\n  \"nombre\": \"Carlos López\",\n  \"role\": \"PROPIETARIO\"\n}"
            }
          }
        },
        {
          "name": "Register (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@inmobiliaria.com\",\n  \"password\": \"Admin1234!\",\n  \"nombre\": \"Administrador\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Login ★ (guarda token automáticamente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token guardado:', json.token);",
                  "    pm.test('Login exitoso', () => pm.response.to.have.status(200));",
                  "} else {",
                  "    pm.test('Login fallido', () => { throw new Error(json.message); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"juan\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Validar Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/validate?token={{token}}"
            }
          }
        }
      ]
    },

    {
      "name": "👤 Usuario Service",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/usuarios/health" } }
        },
        {
